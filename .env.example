USER_DATABASE_URL=<postgres-url>
OGCODE_DATABASE_URL=<postgres-url>
# Used by npm run origin-ai:vectors:* scripts. Keep this as a normal postgres:// URL for Node.
ORIGIN_AI_DATABASE_URL=<postgres-url>
GRADER_SERVICE_URL=<grader-service-url>
GRADER_SERVICE_TOKEN=<grader-service-token>
GRADER_SERVICE_TIMEOUT_MS=<timeout-ms>
ANALYTICS_SERVICE_URL=<analytics-service-url>
ANALYTICS_SERVICE_TOKEN=<analytics-service-token>
ANALYTICS_SERVICE_TIMEOUT_MS=<timeout-ms>
ORIGIN_AI_SERVICE_URL=<origin-ai-service-url>
ORIGIN_AI_SERVICE_TOKEN=<origin-ai-service-token>
NEXT_PUBLIC_ORIGIN_AI_URL=<origin-ai-public-url>

# Optional local AI Solver compatibility service. Leave empty unless running that service.
AI_SOLVER_SERVICE_URL=

# Production-only rate limiting backend. Leave unset for local development.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare R2 object storage for uploaded/public media.
# Keep access keys server-only. Use a custom public hostname/CDN for images rendered by Next.
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_BUCKET_NAME=<r2-bucket-name>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_ENDPOINT=https://<cloudflare-account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://<media-domain>
NEXT_PUBLIC_R2_PUBLIC_HOSTNAME=<media-domain-hostname>

# Optional production metrics export.
METRICS_OTLP_HTTP_ENDPOINT=<metrics-otlp-http-endpoint>
METRICS_OTLP_HTTP_TOKEN=<metrics-otlp-http-token>

# Server-only secrets. Never expose these as NEXT_PUBLIC_*.
# Generate JWT secrets with:
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
AUTH_JWT_SECRET_CURRENT=<32-plus-byte-base64url-secret>
# Optional during key rotation. Keep only until old 10-minute access JWTs expire.
AUTH_JWT_SECRET_PREVIOUS=
ROOM_CODE_SECRET=<32-plus-character-random-secret>
OPTION_SHUFFLE_SECRET=<32-plus-character-random-secret>
INTERNAL_CRON_TOKEN=<32-plus-character-random-secret>

NEXT_PUBLIC_API_URL=<api-base-url>
NEXT_PUBLIC_SITE_URL=<public-site-url>
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
GEMINI_MODEL=<gemini-model>
GEMINI_STT_MODEL=<gemini-stt-model>
GEMINI_LIVE_MODEL=<gemini-live-model>
GEMINI_TTS_MODEL=<gemini-tts-model>
GEMINI_LIVE_VOICE_NAME=<gemini-voice-name>
ORIGIN_AI_PROVIDER_TIMEOUT_MS=<timeout-ms>

# Email Configuration (SMTP)
SMTP_HOST=<smtp-host>
SMTP_PORT=<smtp-port>
SMTP_USER=<smtp-username>
SMTP_PASS=<smtp-app-password>
EMAIL_FROM=<email-from>
