# document-import-service — Phase 10 FastAPI worker.
#
# Postgres connection (same DB as the rest of ORIGIN; cross-schema FKs to
# app.* and content.* must validate).
DOCUMENT_IMPORT_DATABASE_URL=postgresql://origin:origin123@127.0.0.1:54329/origin_v1_ogcode

# Bearer secret Next.js uses when calling /v1/import-jobs/{id}/run.
# Must match DOCUMENT_IMPORT_SERVICE_TOKEN on the Next.js side.
DOCUMENT_IMPORT_SERVICE_TOKEN=<document-import-service-token>

DOCUMENT_IMPORT_LOG_LEVEL=INFO

# Cloudflare R2 — source-file fetch. The Next.js side uploads to R2
# first; this service GETs by (bucket, key) recorded in
# content.assets / import.document_import_jobs.source_asset_id.
R2_ENDPOINT_URL=https://<cloudflare-account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_DEFAULT_BUCKET=<r2-bucket-name>

# Optional — Gemini Vision multimodal fallback. When GEMINI_API_KEY is
# unset the pipeline still runs but skips the vision call for
# low-confidence pages.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-3.5-flash

# Force the classifier into HYBRID_RECONCILE mode for every job — useful
# for regression-corpus runs in CI; leave false in production.
DOCUMENT_IMPORT_FORCE_HYBRID=false
