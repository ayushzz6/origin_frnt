{
  "name": "new-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test:unit": "tsx --test tests/*.test.ts tests/**/*.test.ts",
    "db:up": "docker compose -f docker-compose.postgres.yml up -d postgres",
    "db:down": "docker compose -f docker-compose.postgres.yml down",
    "db:logs": "docker compose -f docker-compose.postgres.yml logs -f postgres",
    "ogcode:import": "node --env-file=.env.local scripts/import-ogcode-questions.mjs",
    "ogcode:import:replace": "node --env-file=.env.local scripts/import-ogcode-questions.mjs --replace",
    "ogcode:import:dry-run": "node scripts/import-ogcode-questions.mjs --dry-run",
    "origin-ai:vectors:export": "node --env-file=.env.local scripts/origin-ai-vectors.mjs export",
    "origin-ai:vectors:import": "node --env-file=.env.local scripts/origin-ai-vectors.mjs import",
    "origin-ai:vectors:import:replace": "node --env-file=.env.local scripts/origin-ai-vectors.mjs import --replace",
    "origin-ai:seed-embeddings": "cd ../origin-ai && .venv/bin/python seed_embeddings.py",
    "origin-ai:seed-embeddings:replace": "cd ../origin-ai && .venv/bin/python seed_embeddings.py --replace"
  },
